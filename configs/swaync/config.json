* {
  font-size: 1rem;
  font-weight: 900;
  all: unset;
  font-family: "Fira Sans Semibold", "Font Awesome 7 Free", "Font Awesome 7 Brands", "Font Awesome 6 Free", "Font Awesome 6 Brands", FontAwesome, Roboto, Helvetica, Arial, sans-serif;
  transition: 200ms;
}
.widget-mpris {
  all: unset;
}
.floating-notifications.background .notification-row .notification-background .notification {
    background-color: @surface;
    border-radius: 12px;
    background: radial-gradient(circle at 55% -80%, alpha(@primary, 1), alpha(black,0.6)) padding-box, linear-gradient(transparent, alpha(white, 0.5)) padding-box;
    border: 1px solid @on_surface;
    opacity:1.0;
    margin:10px;
    margin-right:18px;
    box-shadow: 1 1 5 1px @shadow;
}
.floating-notifications.background .notification-row .notification-background .notification.critical {
    background-color: @surface;
    border-radius: 12px;
    background: radial-gradient(circle at 55% -80%, alpha(@primary, 1), alpha(black,0.6)) padding-box, linear-gradient(transparent, alpha(red, 0.5)) padding-box;
    border: 1px solid @on_surface;
    opacity:1.0;
    margin:10px;
    margin-right:18px;
    box-shadow: 1 1 5 1px @shadow;
}
/*This is the margin for the floating notifications on desktop only!*/
.floating-notifications.background
  .notification-row
  .notification-background
  .notification
  .notification-content {
  margin: 0rem;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .notification
  > *:last-child
  > * {
  min-height: 1.5em;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .notification
  > *:last-child
  > *
  .notification-action {
  border-radius: 0.5rem;
  background-color: alpha(@crust, 0.95);
  margin: 0.4rem;
  border: 1px solid transparent;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .notification
  > *:last-child
  > *
  .notification-action:hover {
  background-color: @hover;
  border: 1px solid @primary;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .notification
  > *:last-child
  > *
  .notification-action:active {
  background-color: @primary;
  color: @text;
}
.summary {
  font-weight: 800;
  font-size: 1.15rem;
  padding: 5px 15px;
}
.body {
  padding: 5px 15px;
  font-size: 0.8rem;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .close-button {
  background: transparent;
  border-radius: 7px;
  color: @text;
  background-color: alpha(#fff, 0.5);
  margin: 0px;
  padding: 2px;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .close-button:hover {
  background-color: @primary;
  border-radius: 12px;
}
.floating-notifications.background
  .notification-row
  .notification-background
  .close-button:active {
  background-color: @primary;
  color: @text;
}
.notification.critical progress {
  background-color: @primary;
}
.notification.low progress,
.notification.normal progress {
  background-color: @primary;
}
